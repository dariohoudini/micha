# ─────────────────────────────────────────────────────────────────────
# MICHA Express — environment template
# Copy to `.env` and fill in. Vars below match exactly what config/
# settings.py reads. In production (DEBUG=False) the boot guard REFUSES
# to start until the four "REQUIRED IN PRODUCTION" blocks are set.
# ─────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION. Must be >= 40 chars and not the dev default.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ────────────────────────────────────────────
# REQUIRED IN PRODUCTION. The app switches to PostgreSQL as soon as
# DB_NAME is set; leave ALL of these unset to use the local SQLite dev
# fallback. (Note: there is NO DATABASE_URL support — use these discrete
# vars.) A production deploy with DB_NAME unset is refused at boot.
DB_NAME=micha
DB_USER=micha_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
# Optional connection-pool tuning (defaults shown):
# DB_CONN_MAX_AGE=60

# Optional read-replica. When DB_REPLICA_HOST is set, read-heavy apps
# (analytics/search/reviews/...) route to the replica; writes + money/
# auth apps stay on primary. Leave unset to disable.
# DB_REPLICA_HOST=
# DB_REPLICA_NAME=
# DB_REPLICA_USER=
# DB_REPLICA_PASSWORD=
# DB_REPLICA_PORT=5432

# ── Field encryption ─────────────────────────────────────────────────
# REQUIRED IN PRODUCTION. Fernet key encrypting bank accounts, 2FA
# secrets, and ID fields. Rotating/losing it makes those columns
# unreadable. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── Payments — APPYPAY / Multicaixa Express (EMIS) ───────────────────
# REQUIRED IN PRODUCTION. HMAC secret for the inbound payment webhook —
# the authoritative "paid" signal. If unset/left as dev-secret, PAID
# webhooks are forgeable and the app refuses to boot.
APPYPAY_WEBHOOK_SECRET=
MULTICAIXA_API_KEY=your-key
MULTICAIXA_SECRET=your-secret

# ── Redis (cache + Celery broker + Channels layer) ───────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Production hardening toggles ─────────────────────────────────────
# Set FORCE_HTTPS=true behind your TLS terminator to enable SSL redirect,
# HSTS, and secure cookies.
# FORCE_HTTPS=true
# Row-Level Security (Postgres only). Leave 0 until validated on a real
# Postgres staging environment — enabling it blind can lock out queries.
# RLS_ENABLED=0
# First migrate against a FRESH db trips the migration guard on protected
# tables (safe on empty tables only). Ack just for the initial migrate:
# MIGRATION_UNSAFE_ALLOWED=1

# ── Third-party login (optional) ─────────────────────────────────────
# If GOOGLE_LOGIN_ENABLED=1, GOOGLE_CLIENT_ID MUST be set (empty audience
# accepts tokens from any Google project — the app refuses to boot).
# GOOGLE_LOGIN_ENABLED=0
# GOOGLE_CLIENT_ID=

# ── AI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Twilio (SMS/OTP) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Firebase (push notifications) ────────────────────────────────────
FCM_SERVER_KEY=your-key

# ── Admin ────────────────────────────────────────────────────────────
ADMIN_URL=django-admin/
