# ── Core ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-50-plus-char-random-secret-key-here-never-commit-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# SECURITY: Randomise admin URL so bots cannot find it
ADMIN_URL=xK9mQ2pL8vN3/

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=micha
DB_USER=micha_user
DB_PASSWORD=strong-random-password-here
DB_HOST=localhost
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@yourdomain.com
EMAIL_HOST_PASSWORD=your-mailgun-password

# ── AWS S3 (media files) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_CLOUDFRONT_DOMAIN=

# ── Firebase (push notifications) ────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/123456

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Encryption (field-level for bank accounts + national IDs) ─────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── Payment gateways ─────────────────────────────────────────────────────────
FLUTTERWAVE_SECRET_HASH=your-flutterwave-webhook-hash
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Social Auth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
APPLE_CLIENT_ID=your-apple-service-id
